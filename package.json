{
  "name": "cronograma-financeiro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Planejamento financeiro preditivo (single-user, pt-BR, R$).",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @cf/shared && npm run build -w @cf/api",
    "typecheck": "npm run typecheck -w @cf/shared && npm run typecheck -w @cf/api && tsc --noEmit -p tsconfig.json",
    "test": "npm run test -w @cf/shared",
    "dev": "npm run dev -w @cf/api",
    "db:migrate": "npm run db:migrate -w @cf/api",
    "db:generate": "npm run db:generate -w @cf/api",
    "db:seed": "npm run db:seed -w @cf/api",
    "db:reset": "npm run db:reset -w @cf/api",
    "db:studio": "npm run db:studio -w @cf/api",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "prepare": "npm run build -w @cf/shared",
    "vercel-build": "npm run build -w @cf/shared && npm run db:generate -w @cf/api && npm run db:deploy -w @cf/api && npm run build -w @cf/web"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
