# Banco de dados — Postgres (Neon/Vercel Postgres). Um único banco serve dev local e produção.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
# Conexão direta (sem pooler) — só o Prisma Migrate usa, para os locks de advisory funcionarem.
DATABASE_URL_UNPOOLED="postgresql://user:pass@host/db?sslmode=require"

# Porta da API (dev local)
PORT=3333

# WhatsApp Cloud API (Meta) — bot de comandos por WhatsApp (aporte/resgate/gasto).
# Ver README para o passo a passo de obtenção de cada valor no painel da Meta.
WHATSAPP_VERIFY_TOKEN="escolha-uma-string-aleatoria-qualquer"
WHATSAPP_APP_SECRET="App Secret — em App Settings > Basic, no painel da Meta"
WHATSAPP_ACCESS_TOKEN="token de acesso — permanente, via System User no Business Manager"
WHATSAPP_PHONE_NUMBER_ID="ID do número de teste, em WhatsApp > API Setup"
WHATSAPP_ALLOWED_NUMBER="seu número em E.164 sem '+', ex.: 5511999998888"
